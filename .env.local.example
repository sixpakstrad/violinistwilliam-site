# These same names must exist in the deployed environment.
# Do not paste real secret values into this example file.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# Comma-separated Clerk user IDs allowed to access admin/request dashboards.
# Find this in Clerk Dashboard > Users > select your user > User ID.
ADMIN_USER_IDS=
# Optional single-user-ID form, also supported for one approved admin:
ADMIN_CLERK_USER_ID=
# Optional comma-separated admin emails. User IDs are still preferred.
ADMIN_EMAILS=

# Server-side Supabase CSV import settings.
# SUPABASE_SERVICE_ROLE_KEY must only be used from scripts/server code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
