# Add these same names in Vercel Project Settings -> Environment Variables.
# Do not paste real secret values into this example file.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# Comma-separated list of email addresses allowed to access admin/request dashboards.
ADMIN_EMAILS=winspirationstudio@gmail.com
# Optional single-email form, also supported:
ADMIN_EMAIL=

# Optional and stronger: comma-separated Clerk user IDs allowed to access admin.
# Find this in Clerk Dashboard > Users > select your user > User ID.
ADMIN_USER_IDS=
# Optional single-user-ID form, also supported:
ADMIN_CLERK_USER_ID=
